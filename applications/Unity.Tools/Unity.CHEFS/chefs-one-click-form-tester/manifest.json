{
  "manifest_version": 3,
  "name": "CHEFS One-Click Form Tester",
  "description": "Fills every reachable CHEFS field until stable, submits the form, and exports crash-safe diagnostic logs.",
  "version": "0.4.0",
  "version_name": "0.4.0 build 2026.07.23.14",
  "minimum_chrome_version": "120",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "downloads",
    "unlimitedStorage",
    "alarms",
    "tabs"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_title": "CHEFS One-Click Form Tester",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "options_page": "options.html",
  "web_accessible_resources": [
    {
      "resources": [
        "page-bridge.js",
        "attachments/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}

@page
@using Unity.AI.Localization
@using Unity.AI.Web.Pages.Prompts
@using Microsoft.Extensions.Localization
@using Volo.Abp.AspNetCore.Mvc.UI.Bootstrap.TagHelpers.Modal
@model CreateModalModel
@inject IStringLocalizer<AIResource> L
@{
    Layout = null;
}

<abp-dynamic-form abp-model="Prompt" asp-page="/Prompts/CreateModal">
    <abp-modal>
        <abp-modal-header title="@L["AIPrompt"].Value"></abp-modal-header>
        <abp-modal-body>
            <abp-form-content />
        </abp-modal-body>
        <abp-modal-footer>
            <button class="btn btn-primary" data-busy-text="Saving..." type="submit">Save</button>
            <button class="btn btn-secondary" data-bs-dismiss="modal" type="button">Cancel</button>
        </abp-modal-footer>
    </abp-modal>
</abp-dynamic-form>

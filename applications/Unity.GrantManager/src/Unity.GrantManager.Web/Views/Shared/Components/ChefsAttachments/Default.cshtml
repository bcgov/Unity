@using Microsoft.Extensions.Localization
@using Unity.GrantManager.Localization

@inject IStringLocalizer<GrantManagerResource> L
<div class="attachments__title-button-split">
    <div class="submission-title">
        <h6 class="fw-bold px-3 pt-4 pb-2 m-0">Submission Attachments</h6>
    </div>
    <div class="submission-button-section me-3">
        @if (ViewBag.IsAIAttachmentSummariesEnabled)
        {
            <button type="button" class="btn unt-btn-outline-primary btn-outline-primary me-2" id="generateAiSummaries" title="Generate AI Summaries">
                <span class="ai-button-content">
                    <i class="unt-icon-sm fa-solid fa-wand-magic-sparkles"></i>
                    <span>Generate Summary</span>
                </span>
            </button>
            <button type="button" class="btn unt-btn-outline-primary btn-outline-primary me-2" id="toggleAllAISummaries" title="Toggle AI Summaries">
                <span class="ai-button-content">
                    <i class="unt-icon-sm fa-solid fa-chevron-down"></i>
                    <span>Show Summaries</span>
                </span>
            </button>
        }
        <button type="button" class="btn unt-btn-outline-primary btn-outline-primary me-2" id="downloadAll">
            <span class="ai-button-content">
                <i class="unt-icon-sm fl fl-download"></i>
                <span>Download All</span>
            </span>
        </button>
        <button type="button" class="btn unt-btn-outline-primary btn-outline-primary me-2" id="resyncSubmissionAttachments" abp-tooltip="@L["ApplicationList:ResyncSubmissionAttachmentsButton"].Value"><i class="unt-icon-sm fl fl-synch"></i></button>
        @* <abp-button id="resyncSubmissionAttachments"
                        icon-type="Other"
                        size="Large"
                        icon="fl fl-synch"
                        abp-tooltip="@L["ApplicationList:ResyncSubmissionAttachmentsButton"].Value"
                        button-type="Light" /> *@
    </div>
</div>
@if (ViewBag.IsAIAttachmentSummariesEnabled && ViewBag.IsDevPromptControlsEnabled)
{
    <div class="px-3 pb-2 d-flex align-items-center gap-3 flex-wrap" id="attachmentPromptControls">
        <div>
            <label class="form-label mb-1" for="attachmentPromptVersion">Prompt Version</label>
            <select id="attachmentPromptVersion" class="form-select form-select-sm">
                @if (ViewBag.DefaultPromptVersion == "v0")
                {
                    <option value="v0" selected>v0</option>
                    <option value="v1">v1</option>
                }
                else
                {
                    <option value="v1" selected>v1</option>
                    <option value="v0">v0</option>
                }
            </select>
        </div>
        <div class="form-check mt-4">
            <input class="form-check-input" type="checkbox" id="attachmentCapturePromptIo">
            <label class="form-check-label" for="attachmentCapturePromptIo">Capture prompt I/O</label>
        </div>
    </div>
    <div class="px-3 pb-2 d-none" id="attachmentPromptCaptureContainer">
        <div class="alert alert-secondary mb-0">
            <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                <div class="fw-bold mb-0">Captured Prompt I/O</div>
                <button type="button" class="btn btn-sm unt-btn-outline-primary btn-outline-primary ai-prompt-capture-copy-btn" data-target="#attachmentPromptCaptureOutput">Copy All</button>
            </div>
            <textarea class="form-control form-control-sm ai-prompt-capture-output" id="attachmentPromptCaptureOutput" readonly spellcheck="false"></textarea>
        </div>
    </div>
}
<div class="px-3">
    <abp-table id="ChefsAttachmentsTable" hoverable-rows="true" class="attachments-table" data-resize-aware="true"></abp-table>
</div>

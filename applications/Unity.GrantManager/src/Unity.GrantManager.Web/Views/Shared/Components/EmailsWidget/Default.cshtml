@using Unity.GrantManager.Web.Views.Shared.Components.EmailsWidget;
@using Microsoft.AspNetCore.Mvc.Localization;
@using Unity.GrantManager.Localization;
@using Microsoft.Extensions.Localization;
@using Volo.Abp.Authorization.Permissions;
@model EmailsWidgetViewModel;

@inject IHtmlLocalizer<GrantManagerResource> L
@inject IPermissionChecker PermissionChecker
@inject IStringLocalizerFactory StringLocalizerFactory
@{
    Layout = null;
    var sendEmailGranted    = await PermissionChecker.IsGrantedAsync("Notifications.Email.Send");
    var emailFieldsetState  = sendEmailGranted ? string.Empty : "disabled";
}

<div id=" emails-div@(Model.ApplicationId)" class="mt-2  emails-container" data-count="0" data-counttag="application_emails_count">

    <div id="modal-background"></div>

    <abp-button 
        id="btn-new-email" 
        text="New Email"
        icon-type="Other" 
        icon="fa-solid fa-plus" 
        button-type="Light"
        abp-if="@sendEmailGranted" />

    <abp-alert
        id="email-alert-readonly"
        alert-type="Secondary" 
        abp-if="@(!sendEmailGranted)">
        Please select from the email history below.
    </abp-alert>

    <div id="modal-content" class="modal-content" title="Email Send Confrirmation">
        <h2 class="swal2-title" style="text-align: center;">Confirm Action</h2>
        <abp-column id="spinner-modal" class="modal-content">
            <abp-row class="m-0 p-0">
                <abp-column size="_12" class="px-1">
                    <p>
                        <div id="email-spinner"></div>
                        <span class="email-spinner-text email-spinner confirmation-label">Sending email...</span>
                    </p>
                </abp-column>
            </abp-row>
        </abp-column>
        <abp-row class="m-0 p-0" id="confirmation-modal">
            <abp-column size="_12" class="px-1">
                <p>
                    <label id="confirmation-label" for="btn-send" class="col-form-label confirmation-label" ref="label">
                        Are you sure you want to send this email?
                    </label>
                </p>
            </abp-column>
        </abp-row>
        <abp-row class="m-0 p-0">
            <abp-column size="_12" class="px-1">
                <abp-modal-footer>
                    <abp-button id="btn-confirm-send" text="Send Email" class="swal2-confirm btn btn-primary swal2-styled" type="button" button-type="Primary"></abp-button>
                    <abp-button id="btn-cancel-email" class="swal2-cancel btn btn-secondary swal2-styled" data-dismiss="modal" aria-label="Cancel" text="Cancel" button-type="Secondary"></abp-button>
                </abp-modal-footer>
            </abp-column>
        </abp-row>
    </div>


    <form id="EmailForm" class="email-form" autocomplete="off">
        <abp-input type="hidden" id="ApplicationId" asp-for="@Model.ApplicationId" />
        <fieldset @emailFieldsetState>
            <legend class="d-none">Email Form</legend>
            <input type="hidden" id="EmailId" name="EmailId" />
            <input type="hidden" id="OriginalDraftEmailTo" value="@Model.EmailTo" />
            <input type="hidden" id="OriginalDraftEmailCC" value="@Model.EmailCC" />
            <input type="hidden" id="OriginalDraftEmailBCC" value="@Model.EmailBCC" />
            <input type="hidden" id="OriginalDraftEmailFrom" value="@Model.EmailFrom" />
            <input type="hidden" id="OriginalDraftEmailSubject" />
            <input type="hidden" id="OriginalDraftEmailBody" />

            <abp-row class="m-0 p-0">
                <abp-column id="templateListContainer" size="_10" class="px-2">
                    <abp-select asp-for="@Model.EmailTemplate" asp-items="@Model.TemplatesList" id="EmailTemplate">
                        <option value="">Please select</option>
                    </abp-select>
                </abp-column>
                <abp-column id="templateTextContainer" size="_10" class="px-1">
                    <abp-input id="EmailTemplateName" asp-for="@Model.EmailTemplateName"></abp-input>
                </abp-column>
            </abp-row>
            <abp-row class="m-0 p-0">
                <abp-column size="_10" class="px-1">
                    <abp-input asp-for="@Model.EmailTo" class="email-input" />
                </abp-column>
            </abp-row>
            <abp-row class="m-0 p-0">
                <abp-column size="_10" class="px-1">
                    <abp-input asp-for="@Model.EmailCC" class="email-input" />
                </abp-column>
            </abp-row>
            <abp-row class="m-0 p-0">
                <abp-column size="_10" class="px-1">
                    <abp-input asp-for="@Model.EmailBCC" class="email-input" />
                </abp-column>
            </abp-row>
            <abp-row class="m-0 p-0">
                <abp-column size="_10" class="px-1">
                    <abp-input asp-for="@Model.EmailFrom" class="email-input" />
                </abp-column>
            </abp-row>
            <abp-row class="m-0 p-0">
                <abp-column size="_10" class="px-1">
                    <abp-input asp-for="@Model.EmailSubject" class="email-input" />
                </abp-column>
            </abp-row>
            @if (Model.EnableEmailDelay)
            {
                <abp-row class="m-0 p-0 mb-3">
                    <abp-column size="_10" class="px-1">
                        <label class="form-label" for="btn-clear-schedule">
                            Send Date &amp; Time
                            <span class="text-muted fw-normal ms-1 send-date-hint">( leave blank to send immediately )</span>
                        </label>
                        <div class="px-1 d-flex align-items-center gap-2 flex-wrap">
                            <button type="button" id="btn-open-schedule-modal" class="btn btn-outline-secondary btn-sm">
                                <i class="fa fa-calendar me-1"></i>Schedule Send
                            </button>
                            <span id="send-on-display" class="text-muted"></span>
                            <button type="button" id="btn-clear-schedule" class="btn btn-light">
                                Clear
                            </button>
                        </div>
                        <div id="delay-datetime-validation" class="text-danger mt-1"></div>
                        <!-- Hidden field carries the UTC ISO value submitted to the API -->
                        <input id="SendOnDateTime" name="SendOnDateTime" type="hidden" />
                    </abp-column>
                </abp-row>
            }
            <abp-row class="m-0 p-0">
                <abp-column size="_10" class="px-1">
                    <abp-input asp-for="@Model.EmailBody" class="email-input" />
                </abp-column>
            </abp-row>
        </fieldset>
        <div id="email-attachments-section" style="display:none">
            <abp-row class="m-0 p-0">
                <abp-column size="_10" class="px-1">
                    <h6 class="fw-bold pt-3 pb-1 m-0">Attachments</h6>
                    <abp-table id="EmailAttachmentsTable"
                               hoverable-rows="true"
                               class="attachments-table nowrap"></abp-table>
                    <div id="attachment-upload-progress" style="display:none" class="mt-2 mb-1">
                        <div class="progress">
                            <progress id="attachment-upload-progress-bar"
                                 class="progress-bar progress-bar-striped progress-bar-animated"
                                 style="width:0%"
                                 value="0"
                                 max="100">0%</progress>
                        </div>
                    </div>
                    <div id="email-attachment-size-error" class="alert alert-danger mt-2" style="display:none">
                        <i class="fa fa-exclamation-triangle me-1"></i>
                        <span id="email-attachment-size-error-message"></span>
                    </div>
                    <div class="d-flex justify-content-end mt-2 mb-1">
                        <form id="email-attachment-form" enctype="multipart/form-data">
                            <input id="email_attachment_upload" type="file" multiple
                                   style="display:none" />
                            <abp-button text="Add Attachments"
                                        id="email_attachment_upload_btn"
                                        icon-type="Other"
                                        icon="fl fl-plus"
                                        button-type="Light" />
                        </form>
                    </div>
                </abp-column>
            </abp-row>
        </div>
        <abp-row class="m-0 p-0" abp-if="@sendEmailGranted">
            <abp-column size="_10" class="px-1">
            <abp-modal-footer>
                <abp-button id="btn-save"
                            icon-type="Other"
                            icon="fl fl-save"
                            class="btn-save"
                            text="Save"
                            type="button"
                            button-type="Primary" data-applicationId="@Model.ApplicationId"></abp-button>

                <abp-button id="btn-send"
                            class="btn-send"
                            text="Send"
                            type="submit"
                            button-type="Primary" data-applicationId="@Model.ApplicationId"></abp-button>

                <abp-button id="btn-send-discard"
                            class="close btn-send-discard"
                            data-dismiss="modal"
                            aria-label="Discard"
                            text="Discard"
                            button-type="Secondary" data-applicationId="@Model.ApplicationId"></abp-button>

                <abp-button id="btn-send-close"
                            class="close btn-send-close"
                            data-dismiss="modal"
                            aria-label="Close"
                            text="Close"
                            button-type="Secondary" data-applicationId="@Model.ApplicationId"></abp-button>
            </abp-modal-footer>
        </abp-column>
    </abp-row>
</form>

<!-- Schedule Send Modal -->
<div id="schedule-send-modal-backdrop"></div>
<div id="schedule-send-modal">
    <h5 id="schedule-modal-title" class="mb-3">Schedule Send Date &amp; Time</h5>

    <div class="mb-3 d-flex flex-wrap gap-1">
        <button type="button" class="btn btn-sm btn-outline-secondary delay-shortcut" data-days="1">+1 day</button>
        <button type="button" class="btn btn-sm btn-outline-secondary delay-shortcut" data-days="3">+3 days</button>
        <button type="button" class="btn btn-sm btn-outline-secondary delay-shortcut" data-days="7">+1 week</button>
        <button type="button" class="btn btn-sm btn-outline-secondary delay-shortcut" data-days="14">+2 weeks</button>
        <button type="button" class="btn btn-sm btn-outline-secondary delay-shortcut" data-days="30">+1 month</button>
    </div>

    <div class="d-flex align-items-center gap-2 mb-3">
        <label class="mb-0 text-muted schedule-modal-label" for="DelayDaysHelper">Or delay by</label>
        <input id="DelayDaysHelper" type="number" class="form-control form-control-sm" min="1" max="365" placeholder="days">
        <span class="text-muted" style="font-size:0.9em;">days</span>
    </div>

    <div class="mb-1">
        <label for="SendOnDateTimePicker" class="form-label mb-1 schedule-modal-label">Date &amp; Time (BC PST)</label>
        <div class="input-group">
            <input id="SendOnDateTimePicker" type="datetime-local" class="form-control" />
            <button type="button" id="btn-picker-ok" class="input-group-text">OK</button>
        </div>
        <small class="text-muted">Must be a future date and time.</small>
    </div>
    <div id="schedule-modal-validation" class="text-danger mt-1"></div>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <button type="button" id="btn-schedule-cancel" class="btn btn-secondary btn-sm">Cancel</button>
        <button type="button" id="btn-schedule-confirm" class="btn btn-primary btn-sm">Confirm</button>
    </div>
</div>

</div>
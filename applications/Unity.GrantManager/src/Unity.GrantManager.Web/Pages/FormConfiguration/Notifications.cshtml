@page
@model Unity.GrantManager.Web.Pages.FormConfiguration.NotificationsModel
@{
    ViewData["Title"] = "Form Configuration";
}
@section Scripts {
    <script src="/libs/select2/js/select2.min.js"></script>
    <script src="/js/formConfiguration/NotificationsPreview.js"></script>
    <script src="/js/formConfiguration/Notifications.js"></script>
}


<div class="container-fluid">
    <input type="hidden" id="applicationFormId" value="@Model.FormId" />
    <div class="row mb-3">
        <div class="col-8">
            <h3>Form Configuration</h3>
        </div>
    </div>

    <ul class="nav nav-tabs mb-3">
        <li class="nav-item"><a class="nav-link" href="#">Details</a></li>
        <li class="nav-item"><a class="nav-link" href="#">Workflow</a></li>
        <li class="nav-item"><a class="nav-link" href="#">Other Configuration</a></li>
        <li class="nav-item"><a class="nav-link active" href="#">Notifications</a></li>
    </ul>

    <div class="row">
        <div class="col-lg-8">
            <div class="card mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="mb-0">Scheduled Notifications</h5>
                        <button id="btn-open-create" class="btn btn-primary btn-sm">+ Create Automated Notification</button>
                    </div>

                    <table id="NotificationsTable" class="table table-striped table-bordered" style="width:100%">
                        <thead>
                            <tr>
                                <th>Template</th>
                                <th>Trigger Type</th>
                                <th>Trigger Detail</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>

            <div class="card mb-4 p-3">
                <h5>Create Automated Email Notification</h5>
                <div class="row g-3">
                    <div class="col-md-8">
                        <div class="mb-3">
                            <label for="cf_template" class="form-label">Select Template</label>
                            <select id="cf_template" class="form-select"></select>
                        </div>

                        <div class="mb-3">
                            <label for="triggerType" class="form-label">Trigger Type</label>
                            <div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="triggerType" id="triggerEvent" value="Event" checked>
                                    <label class="form-check-label" for="triggerEvent">Event</label>
                                </div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="triggerType" id="triggerDate" value="Date">
                                    <label class="form-check-label" for="triggerDate">Date</label>
                                </div>
                            </div>
                        </div>

                        <div id="dateSection" style="display:none">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="cf_dateField" class="form-label">Date Field</label>
                                    <select id="cf_dateField" class="form-select">
                                        <option value="DueDate">Due Date</option>
                                        <option value="NotificationDate">Notification Date</option>
                                        <option value="ProjectStartDate">Project Start Date</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div id="eventSection">
                            <div class="mb-3">
                                <label for="cf_eventType" class="form-label">Event Type</label>
                                <select id="cf_eventType" class="form-select">
                                    <option value="ApplicationStatusChange">Application Status Change</option>
                                    <option value="SubmissionCreated">Submission Created</option>
                                    <option value="AssignmentCompleted">Assignment Completed</option>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label for="cf_appStatus" class="form-label">Application Status</label>
                                <select id="cf_appStatus" class="form-select"></select>
                            </div>

                            <div class="mb-3">
                                <label for="cf_recipientCategory" class="form-label">Recipient Category</label>
                                <select id="cf_recipientCategory" class="form-select">
                                    <option value="Internal">Internal</option>
                                    <option value="External">External</option>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label for="cf_recipient" class="form-label">Recipient</label>
                                <select id="cf_recipient" class="form-select" multiple></select>
                            </div>
                        </div>

                    </div>

                    <div class="col-md-4">
                        <div class="card">
                            <div class="card-body">
                                <label for="previewCard" class="form-label">Template Preview</label>
                                <div id="previewCard" class="border p-2" style="min-height:200px; background:#fff"></div>
                            </div>
                        </div>
                    </div>

                    <div class="col-12 d-flex justify-content-end">
                        <button id="btn-cancel" class="btn btn-outline-secondary me-2">Cancel</button>
                        <button id="btn-save" class="btn btn-primary">Save Notification</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            @* Placeholder for any extra widgets *@
            @await Component.InvokeAsync("Notifications", new { formid = Model.FormId })
        </div>
    </div>
</div>


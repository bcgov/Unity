@page
@model Unity.GrantManager.Web.Pages.Attachments.PreviewAttachmentModalModel
@using Volo.Abp.AspNetCore.Mvc.UI.Bootstrap.TagHelpers.Modal
@{
    Layout = null;
}

<abp-modal size="ExtraLarge" id="previewAttachmentModal">
    <abp-modal-header title="@Model.DisplayName"></abp-modal-header>
    <abp-modal-body>
        <div id="previewData"
             data-download-url="@Model.DownloadUrl"
             data-file-name="@Model.FileName"
             data-presigned-url-endpoint="@Model.PresignedUrlEndpoint">
        </div>

        <div id="previewSpinner" class="text-center py-5">
            <div class="spinner-border text-secondary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>

        <iframe id="previewFrame" style="width:100%;height:70vh;border:none;display:none;" title="@Model.DisplayName"></iframe>

        <div id="previewDocx" style="display:none;overflow:auto;max-height:70vh;padding:1rem;"></div>

        <div id="previewSheet" style="display:none;overflow:auto;max-height:70vh;"></div>

        <div id="previewImageWrapper" class="text-center" style="display:none;">
            <img id="previewImage" style="max-width:100%;max-height:70vh;" alt="@Model.DisplayName" />
        </div>

        <video id="previewVideo" controls style="display:none;width:100%;max-height:70vh;"></video>

        <audio id="previewAudio" controls style="display:none;width:100%;margin-top:1rem;"></audio>

        <pre id="previewText" style="display:none;overflow:auto;max-height:70vh;padding:1rem;background:#f8f9fa;border-radius:4px;font-size:0.875rem;"></pre>

        <div id="previewFallback" class="text-center py-5" style="display:none;">
            <i class="fa fa-exclamation-circle fa-3x text-muted mb-3" style="display:block;"></i>
            <p class="text-muted">Preview unavailable. The file may be corrupted or in an unsupported format.</p>
        </div>
    </abp-modal-body>
    <abp-modal-footer>
        <a href="@Model.DownloadUrl" class="btn btn-primary" target="_blank" download="@Model.FileName">
            <i class="fl fl-download"></i> Download
        </a>
        <button class="btn btn-secondary" data-bs-dismiss="modal" type="button">Close</button>
    </abp-modal-footer>
</abp-modal>

<script>
(function () {
    var mammothSrc = '/libs/mammoth/mammoth.browser.min.js';
    var xlsxSrc = '/libs/xlsx/dist/xlsx.full.min.js';

    function showEl(id) {
        var spinner = document.getElementById('previewSpinner');
        if (spinner) { spinner.style.display = 'none'; }
        var el = document.getElementById(id);
        if (el) { el.style.display = ''; }
    }

    function showFallback() {
        showEl('previewFallback');
    }

    function loadScript(src, globalName, callback) {
        if (window[globalName]) {
            callback();
            return;
        }
        var script = document.createElement('script');
        script.src = src;
        script.onload = callback;
        script.onerror = function () { showFallback(); };
        document.head.appendChild(script);
    }

    function initPreview(downloadUrl, fileName, presignedUrlEndpoint) {
        var ext = fileName.split('.').pop().toLowerCase();
        var imageExts = ['jpg', 'jpeg', 'png', 'gif', 'webp', 'svg', 'bmp'];
        var videoExts = ['mp4', 'webm', 'ogv'];
        var audioExts = ['mp3', 'wav', 'ogg', 'aac', 'flac'];
        var textExts  = ['txt', 'json', 'xml', 'log'];

        if (ext === 'pdf') {
            fetch(downloadUrl, { credentials: 'include' })
                .then(function (r) {
                    if (!r.ok) { throw new Error('HTTP ' + r.status); }
                    return r.blob();
                })
                .then(function (blob) {
                    var blobUrl = URL.createObjectURL(blob);
                    var frame = document.getElementById('previewFrame');
                    frame.src = blobUrl;
                    showEl('previewFrame');
                })
                .catch(function (e) { console.warn('Preview pdf error:', e); showFallback(); });

        } else if (ext === 'docx' || ext === 'doc') {
            loadScript(mammothSrc, 'mammoth', function () {
                fetch(downloadUrl, { credentials: 'include' })
                    .then(function (r) {
                        if (!r.ok) { throw new Error('HTTP ' + r.status); }
                        return r.arrayBuffer();
                    })
                    .then(function (buf) { return mammoth.convertToHtml({ arrayBuffer: buf }); })
                    .then(function (result) {
                        document.getElementById('previewDocx').innerHTML = result.value;
                        showEl('previewDocx');
                    })
                    .catch(function (e) { console.warn('Preview docx error:', e); showFallback(); });
            });

        } else if (ext === 'xlsx' || ext === 'xls' || ext === 'csv') {
            loadScript(xlsxSrc, 'XLSX', function () {
                fetch(downloadUrl, { credentials: 'include' })
                    .then(function (r) {
                        if (!r.ok) { throw new Error('HTTP ' + r.status); }
                        return r.arrayBuffer();
                    })
                    .then(function (buf) {
                        try {
                            var wb = XLSX.read(buf, { type: 'array' });
                            var ws = wb.Sheets[wb.SheetNames[0]];
                            document.getElementById('previewSheet').innerHTML = XLSX.utils.sheet_to_html(ws, { editable: false });
                            showEl('previewSheet');
                        } catch (e) {
                            console.warn('Preview xlsx error:', e);
                            showFallback();
                        }
                    })
                    .catch(function (e) { console.warn('Preview fetch error:', e); showFallback(); });
            });

        } else if (imageExts.indexOf(ext) !== -1) {
            fetch(downloadUrl, { credentials: 'include' })
                .then(function (r) {
                    if (!r.ok) { throw new Error('HTTP ' + r.status); }
                    return r.blob();
                })
                .then(function (blob) {
                    var img = document.getElementById('previewImage');
                    img.onerror = showFallback;
                    img.onload = function () { showEl('previewImageWrapper'); };
                    img.src = URL.createObjectURL(blob);
                })
                .catch(function (e) { console.warn('Preview image error:', e); showFallback(); });

        } else if (videoExts.indexOf(ext) !== -1) {
            fetch(downloadUrl, { credentials: 'include' })
                .then(function (r) {
                    if (!r.ok) { throw new Error('HTTP ' + r.status); }
                    return r.blob();
                })
                .then(function (blob) {
                    var vid = document.getElementById('previewVideo');
                    vid.onerror = showFallback;
                    vid.src = URL.createObjectURL(blob);
                    showEl('previewVideo');
                })
                .catch(function (e) { console.warn('Preview video error:', e); showFallback(); });

        } else if (audioExts.indexOf(ext) !== -1) {
            fetch(downloadUrl, { credentials: 'include' })
                .then(function (r) {
                    if (!r.ok) { throw new Error('HTTP ' + r.status); }
                    return r.blob();
                })
                .then(function (blob) {
                    var aud = document.getElementById('previewAudio');
                    aud.onerror = showFallback;
                    aud.src = URL.createObjectURL(blob);
                    showEl('previewAudio');
                })
                .catch(function (e) { console.warn('Preview audio error:', e); showFallback(); });

        } else if (textExts.indexOf(ext) !== -1) {
            fetch(downloadUrl, { credentials: 'include' })
                .then(function (r) {
                    if (!r.ok) { throw new Error('HTTP ' + r.status); }
                    return r.text();
                })
                .then(function (text) {
                    document.getElementById('previewText').textContent = text;
                    showEl('previewText');
                })
                .catch(function (e) { console.warn('Preview text error:', e); showFallback(); });

        } else if ((ext === 'pptx' || ext === 'ppt') && presignedUrlEndpoint) {
            fetch(presignedUrlEndpoint, { credentials: 'include' })
                .then(function (r) {
                    if (!r.ok) { throw new Error('HTTP ' + r.status); }
                    return r.json();
                })
                .then(function (data) {
                    var viewerUrl = 'https://view.officeapps.live.com/op/view.aspx?src=' + encodeURIComponent(data.url);
                    var frame = document.getElementById('previewFrame');
                    frame.src = viewerUrl;
                    showEl('previewFrame');
                })
                .catch(function (e) { console.warn('Preview pptx error:', e); showFallback(); });

        } else {
            showFallback();
        }
    }

    var previewData = document.getElementById('previewData');
    if (previewData) {
        initPreview(
            previewData.getAttribute('data-download-url'),
            previewData.getAttribute('data-file-name'),
            previewData.getAttribute('data-presigned-url-endpoint')
        );
    }
})();
</script>

(() => {
    const root = document.querySelector('#nav-addresses');
    if (!root) return 'no #nav-addresses';

    return [...root.querySelectorAll('*')]
      .filter((el) => {
        const cs = getComputedStyle(el);
        const scrollableY = ['auto', 'scroll'].includes(cs.overflowY);
        return scrollableY && el.scrollHeight > el.clientHeight;
      })
      .map((el) => ({
        tag: el.tagName,
        id: el.id,
        class: String(el.className).slice(0, 120),
        overflowY: getComputedStyle(el).overflowY,
        clientHeight: el.clientHeight,
        scrollHeight: el.scrollHeight,
        scrollTop: el.scrollTop
      }));
  })();
